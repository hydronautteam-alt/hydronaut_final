<?xml version="1.0" encoding="utf-8"?>
<robot name="loco" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="Blue"> <color rgba="0.79 0.82 0.93 1" /> </material>
  <material name="DarkGray"> <color rgba="0.3 0.3 0.3 1" /> </material>

 

  <link name="base_link">
  <inertial>
      <mass value="21.3" />
      <origin xyz="0 0 -0.05" rpy="0 0 0" />      
      <inertia ixx="2.5" ixy="0.0" ixz="0.0" 
               iyy="2.5" iyz="0.0" 
               izz="2.5" /> 
    </inertial>

    <visual>
      <geometry> <mesh filename="package://loco_description/meshes/base_link.STL" /> </geometry>
      <material name="Blue" />
    </visual>

    <collision name="main_hull">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry> <box size="0.5 0.44 0.1"/> </geometry>
    </collision>
  </link>
  


  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>1</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <topic>imu</topic> 
    </sensor>
  </gazebo>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.3 0 0" rpy="0 0.785 0"/>
  </joint>

  <link name="camera_link">
  <inertial>
      <mass value="0.3" />
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
    </inertial>
    <visual>
      <geometry> <box size="0.05 0.05 0.05"/> </geometry>
      <material name="DarkGray"/>
    </visual>
  </link>

  <gazebo reference="camera_link">
    <sensor type="camera" name="front_camera">
      <update_rate>30.0</update_rate>
      <visualize>true</visualize>
      <topic>camera</topic> 
      <camera>
        <horizontal_fov>1.396</horizontal_fov>
        <image> <width>640</width> <height>480</height> <format>R8G8B8</format> </image>
        <clip> <near>0.02</near> <far>300</far> </clip>
      </camera>
    </sensor>
  </gazebo>

  <xacro:macro name="make_thruster" params="suffix stl_file x y z axis_x axis_y axis_z">
    <link name="thruster_${suffix}">
      <inertial>
        <mass value="0.1" />
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
      </inertial>
      <visual>
        <geometry> <mesh filename="package://loco_description/meshes/${stl_file}" /> </geometry>
        <material name="DarkGray" />
      </visual>
    </link>

    <joint name="joint_${suffix}" type="continuous">
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0" />
      <parent link="base_link" />
      <child link="thruster_${suffix}" />
      <axis xyz="${axis_x} ${axis_y} ${axis_z}" />
    </joint>

    <gazebo>
      <plugin filename="gz-sim-thruster-system" name="gz::sim::systems::Thruster">
        <joint_name>joint_${suffix}</joint_name>
        <thrust_coefficient>0.05</thrust_coefficient>
        <fluid_density>1000</fluid_density>
        <propeller_diameter>0.1</propeller_diameter>
      </plugin> 
    </gazebo>
  </xacro:macro>

  <xacro:make_thruster suffix="fl" stl_file="link_FL.STL" x="0.191" y="0.178" z="-0.002" axis_x="0.707" axis_y="-0.707" axis_z="0" />
  <xacro:make_thruster suffix="fr" stl_file="Link_FR.STL" x="0.190" y="-0.177" z="-0.002" axis_x="0.707" axis_y="0.707" axis_z="0" />
  <xacro:make_thruster suffix="bl" stl_file="Link_BL.STL" x="-0.203" y="0.166" z="-0.002" axis_x="0.707" axis_y="0.707" axis_z="0" />
  <xacro:make_thruster suffix="br" stl_file="Link_BR.STL" x="-0.204" y="-0.166" z="0.000" axis_x="0.707" axis_y="-0.707" axis_z="0" />
  <xacro:make_thruster suffix="cl" stl_file="Link_CL.STL" x="-0.002" y="0.136" z="-0.011" axis_x="0" axis_y="0" axis_z="1" />
  <xacro:make_thruster suffix="cr" stl_file="link_CR.STL" x="-0.003" y="-0.135" z="-0.010" axis_x="0" axis_y="0" axis_z="1" />

 <gazebo>
    <plugin filename="gz-sim-hydrodynamics-system" name="gz::sim::systems::Hydrodynamics">
      <link_name>base_link</link_name>
      
      <xDotU>-10.0</xDotU> <yDotV>-10.0</yDotV> <zDotW>-10.0</zDotW>
      
      <kDotP>-1.0</kDotP> <mDotQ>-1.0</mDotQ> <nDotR>-1.0</nDotR> 
      
      <xU>-50.0</xU> <yV>-50.0</yV> <zW>-50.0</zW>
      
      <kP>-10.0</kP> <mQ>-10.0</mQ> <nR>-20.0</nR>
    </plugin>
  </gazebo>

 

<gazebo>
  < <plugin name="ArduPilotPlugin" filename="ArduPilotPlugin">
      <fdm_addr>127.0.0.1</fdm_addr>
      <fdm_port_in>9002</fdm_port_in>
      <connectionTimeoutMaxCount>5</connectionTimeoutMaxCount>
      <lock_step>1</lock_step>
      
      <modelXYZToAirplaneXForwardZDown>0 0 0 3.141593 0 0</modelXYZToAirplaneXForwardZDown>
      <gazeboXYZToNED>0 0 0 3.141593 0 0</gazeboXYZToNED>

      <imuName>imu_sensor</imuName>
      <connectionTimeoutMaxCount>5</connectionTimeoutMaxCount>

      <control channel="0" servomin="1100" servomax="1900">
        <type>COMMAND</type>
        <jointName>joint_fr</jointName>
        <multiplier>1</multiplier>
      </control>
      <control channel="1" servomin="1100" servomax="1900">
        <type>COMMAND</type>
        <jointName>joint_fl</jointName>
        <multiplier>1</multiplier>
      </control>
      <control channel="2" servomin="1100" servomax="1900">
        <type>COMMAND</type>
        <jointName>joint_br</jointName>
        <multiplier>1</multiplier>
      </control>
      <control channel="3" servomin="1100" servomax="1900">
        <type>COMMAND</type>
        <jointName>joint_bl</jointName>
        <multiplier>1</multiplier>
      </control>
      <control channel="4" servomin="1100" servomax="1900">
        <type>COMMAND</type>
        <jointName>joint_cr</jointName>
        <multiplier>1</multiplier>
      </control>
      <control channel="5" servomin="1100" servomax="1900">
        <type>COMMAND</type>
        <jointName>joint_cl</jointName>
        <multiplier>1</multiplier>
      </control>
    </plugin>
  </gazebo>


</robot>